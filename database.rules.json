{
  "rules": {
    "users": {
      ".read": true,
      "$uid": {
        ".write": "$uid === auth.uid || auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'",
        "telegramId": { ".write": "true" },
        "telegramUsername": { ".write": "true" },
        "updatedAt": { ".write": "true" }
      }
    },
    "telegram_users": {
      ".read": true,
      ".write": true
    },
    "support_tickets": {
      ".read": "auth != null",
      "$ticketId": {
        ".write": "auth != null"
      }
    },
    "telegram_binding_codes": {
      ".read": true,
      "$code": {
        ".write": true
      }
    },
    "orders": {
      ".read": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'",
      ".indexOn": ["userId"],
      "$orderId": {
        ".read": "true",
        ".write": "(!data.exists() && (newData.child('userId').val() === auth.uid || !newData.child('userId').exists())) || auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
      }
    },
    "products": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "reviews": {
      ".read": true,
      ".write": "auth != null"
    },
    "screenshot_reviews": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "forum": {
      "threads": {
        ".read": "true",
        "$threadId": {
          ".write": "auth != null && (data.child('authorId').val() === auth.uid || !data.exists() || auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com')",
          "viewsCount": {
            ".write": "true"
          },
          "commentsCount": {
            ".write": "auth != null"
          },
          "updatedAt": {
            ".write": "auth != null"
          },
          "reactions": {
            "$uid": {
              ".write": "auth != null && auth.uid === $uid"
            }
          }
        }
      },
      "comments": {
        "$threadId": {
          ".read": "true",
          "$commentId": {
            ".write": "auth != null && (data.child('authorId').val() === auth.uid || !data.exists() || auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com')",
            "reactions": {
              "$uid": {
                ".write": "auth != null && auth.uid === $uid"
              }
            }
          }
        }
      }
    },
    "auctions": {
      ".read": true,
      ".write": "auth != null"
    },
    "box_types": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "box_items": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "gallery": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "settings": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "activities": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "treatments": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "food": {
      ".read": true,
      ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'"
    },
    "giveaways": {
      ".read": true,
      "$giveawayId": {
        ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'",
        "participantsCount": {
          ".write": "auth != null"
        }
      }
    },
    "giveaway_participants": {
      ".read": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'",
      "$giveawayId": {
        ".read": true,
        ".write": "auth.token.email === 'maryanlikesyou@gmail.com' || auth.token.email === 'musevi4ka@gmail.com'",
        "$uid": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}